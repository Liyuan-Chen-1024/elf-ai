{
  "name": "elfai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/client/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "test": "turbo run test",
