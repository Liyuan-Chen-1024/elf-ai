# =====================
# Shared Configuration
# =====================
APP_ENVIRONMENT=development
SENTRY_DSN=your-sentry-dsn

# Logging
DJANGO_LOG_LEVEL=INFO
DJANGO_LOG_RESPONSE_BODY=False
DJANGO_LOG_REQUEST_BODY=False

# =====================
# Frontend Configuration
# =====================

# Server Settings
FRONTEND_PORT=3000

# API Integration
VITE_API_URL=http://localhost:8000/api/v1
VITE_AUTH_TOKEN=
VITE_SENTRY_DSN=your-sentry-dsn

# =====================
# Backend Configuration
# =====================

# Django Core
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=dev-secret-key
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
API_PORT=8000

# API Documentation
API_TITLE=Elf AI API
API_DESCRIPTION=API documentation
API_VERSION=1.0.0

# REST Framework Settings
DRF_PAGE_SIZE=100
DRF_THROTTLE_ANON_RATE=100/day
DRF_THROTTLE_USER_RATE=1000/day

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database Configuration
DB_NAME=elfai
DB_USER=elfai
DB_PASSWORD=elfai
DB_HOST=db
DB_PORT=3306
DATABASE_URL=mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
DB_ROOT_PASSWORD=root

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_INTERNAL_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_INTERNAL_PORT}/0
REDIS_PASSWORD=your-redis-password

# Storage & Media
MEDIA_ROOT=/app/media
MEDIA_URL=/media/
STATIC_ROOT=/app/static
STATIC_URL=static/

# Internationalization
LANGUAGE_CODE=en-us
TIME_ZONE=UTC

# Security
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
DEFAULT_FROM_EMAIL=noreply@elfai.frecar.no

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# LLM Configuration
LLM_API_URL=http://host.docker.internal:11434/api/generate
LLM_MODEL_NAME=deepseek-r1:8b

# Transmission Configuration
TRANSMISSION_HOST=localhost
TRANSMISSION_PORT=9091
TRANSMISSION_USER=
TRANSMISSION_PASSWORD=
TRANSMISSION_DOWNLOAD_DIR=/downloads

