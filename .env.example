# Django
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=mysql://elfai:elfai@db:3306/elfai

# Redis
REDIS_URL=redis://redis:6379/0

# AWS
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-west-2

# Sentry
SENTRY_DSN=your-sentry-dsn

# OpenTelemetry
OTEL_SERVICE_NAME=elfai-media-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://collector:4317

# Media Storage
MEDIA_ROOT=/app/media
MEDIA_URL=/media/

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
VITE_SENTRY_DSN=your-sentry-dsn
VITE_ENVIRONMENT=development

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Django Settings
DEBUG=1
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database Settings
DB_NAME=elfai
DB_USER=elfai
DB_PASSWORD=elfai
DB_HOST=db
DB_PORT=3306
DB_ROOT_PASSWORD=root

# Redis Settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Media Settings
STATIC_ROOT=/app/static

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Monitoring Settings
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# API Keys (Replace with your keys in production)
TMDB_API_KEY=your-tmdb-api-key
TVDB_API_KEY=your-tvdb-api-key

# Transmission Settings
TRANSMISSION_HOST=localhost
TRANSMISSION_PORT=9091
TRANSMISSION_USER=
TRANSMISSION_PASSWORD=
TRANSMISSION_DOWNLOAD_DIR=/downloads

# Security Settings (Production Only)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Logging settings
LOG_LEVEL=INFO
LOG_FILE=/path/to/log/file.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Cache settings
REDIS_PASSWORD=your-redis-password

# API settings
EPGUIDES_API_TIMEOUT=10
EPGUIDES_API_RETRIES=3
