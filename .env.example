# =====================
# Shared configuration
# =====================
APP_ENVIRONMENT=development

# Frontend Configuration
# =====================
# Frontend Configuration
# =====================
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000/api/v1
VITE_SENTRY_DSN=your-sentry-dsn

# =====================
# Backend Configuration
# =====================

# API Settings
API_PORT=8000

DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=dev-secret-key
DJANGO_DEBUG=True
DEBUG=1
SECRET_KEY=change-me-in-production

# Host Settings
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000
DJANGO_CORS_ORIGINS=http://localhost:3000

# Database Configuration
DB_NAME=elfai
DB_USER=elfai
DB_PASSWORD=elfai
DB_HOST=db
DB_PORT=3306
DB_ROOT_PASSWORD=root
DATABASE_URL=mysql://elfai:elfai@db:3306/elfai

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6380
REDIS_INTERNAL_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=your-redis-password

# Storage & Media
MEDIA_ROOT=/app/media
MEDIA_URL=/media/
STATIC_ROOT=/app/static

# Security (Production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Monitoring & Logging
LOG_LEVEL=INFO
LOG_FILE=/path/to/log/file.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
SENTRY_DSN=your-sentry-dsn
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# External Services
TMDB_API_KEY=your-tmdb-api-key
TVDB_API_KEY=your-tvdb-api-key
EPGUIDES_API_TIMEOUT=10
EPGUIDES_API_RETRIES=3

# LLM Configuration
LLM_API_URL=http://host.docker.internal:11434/api/generate
LLM_MODEL_NAME=deepseek-r1:8b

# Transmission Configuration
TRANSMISSION_HOST=localhost
TRANSMISSION_PORT=9091
TRANSMISSION_USER=
TRANSMISSION_PASSWORD=
TRANSMISSION_DOWNLOAD_DIR=/downloads
