[flake8]
max-line-length = 120
exclude =
    .git,
    __pycache__,
    migrations,
    .vscode-server,
    settings.py,
    manage.py,
    portal/settings/*.py,
    env,
    venv,
    .venv,
    .tox,
    .eggs,
    *.egg
ignore =
    E203,
    W503,
    F403,
    F405,  
    E501,
    DJ01,
    DJ08,
    C901,
    E712,
    W605
enable-extensions = G
application-import-names = apps
show-source = True
count = True
format = pylint
max-complexity = 10